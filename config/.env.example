# ══════════════════════════════════════
# AI Personal Assistant — Configuration
# ══════════════════════════════════════

# ── App ──
APP_NAME=AI Personal Assistant
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-random-secret-key

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://assistant:password@localhost:5432/ai_assistant
DATABASE_ECHO=false

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ADMIN_TELEGRAM_ID=your-telegram-user-id
WEBHOOK_URL=https://your-domain.com/api/v1/webhook/telegram

# ── Claude AI ──
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_MODEL=claude-sonnet-4-5-20250929
AI_MAX_TOKENS=2048

# ── Google Calendar (Phase 2) ──
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/auth/google/callback

# ── Celery (Background Tasks) ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
