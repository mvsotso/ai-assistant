# ══════════════════════════════════════
# AI Personal Assistant — Configuration
# ══════════════════════════════════════

# ── App ──
APP_NAME=AI Personal Assistant
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
# IMPORTANT: Generate a random key with: openssl rand -hex 32
APP_SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32

# ── Database (PostgreSQL) ──
# IMPORTANT: Use "db" as host (Docker container name), NOT "localhost"
DATABASE_URL=postgresql+asyncpg://assistant:password@db:5432/ai_assistant
DATABASE_ECHO=false
# This password must match POSTGRES_PASSWORD in docker-compose.prod.yml
DB_PASSWORD=password

# ── Redis ──
# IMPORTANT: Use "redis" as host (Docker container name), NOT "localhost"
REDIS_URL=redis://redis:6379/0

# ── Telegram ──
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Get from @userinfobot on Telegram (a number like 93473297)
ADMIN_TELEGRAM_ID=your-telegram-user-id
# Replace YOUR_DOMAIN with your actual domain
WEBHOOK_URL=https://YOUR_DOMAIN/api/v1/webhook/telegram

# ── Claude AI ──
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
# Options: claude-opus-4-6 (best, $5/$25 per MTok) or claude-sonnet-4-6 (cheaper, $3/$15 per MTok)
AI_MODEL=claude-opus-4-6
AI_MAX_TOKENS=2048

# ── Google Calendar ──
# Get from GCP Console → APIs & Services → Credentials → OAuth client
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# IMPORTANT: This path must match exactly what's registered in GCP Console redirect URIs
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/api/v1/calendar/auth/callback

# ── Celery (Background Tasks) ──
# IMPORTANT: Use "redis" as host, NOT "localhost"
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
